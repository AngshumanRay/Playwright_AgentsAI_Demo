{
  "name": "playwright-agentsai-demo",
  "version": "1.0.0",
  "description": "Playwright AgentsAI Demo — AI-powered BDD test automation with JIRA XRAY integration",
  "main": "utils/index.ts",
  "scripts": {
    "generate": "npx ts-node scripts/generate-from-stories.ts",
    "report": "npx ts-node scripts/generate-report.ts",
    "test": "npx playwright test",
    "test:report": "npx playwright test && npx ts-node scripts/generate-report.ts",
    "test:headed": "RUN_HEADLESS=false npx playwright test",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "encrypt-password": "npx ts-node utils/security/crypto-helper.ts",
    "lint": "npx tsc --noEmit",
    "clean": "rm -rf test-results playwright-report reports/*.html logs/*.log manual-test-cases tests pages/[A-Z]*Page.ts !pages/BasePage.ts"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "jira",
    "xray",
    "data-driven",
    "yaml",
    "iframe",
    "encryption",
    "page-object"
  ],
  "author": "AngshumanRay",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/AngshumanRay/PlaywrightUtilPOC.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/winston": "^2.4.4",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "exceljs": "^4.4.0",
    "mysql2": "^3.18.2",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2"
  }
}
